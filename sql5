# a5 데이터베이스 삭제/생성/선택
DROP DATABASE IF EXISTS a5;
CREATE DATABASE a5;
USE a5;

# 부서(dept) 테이블 생성(create) 및(+) 홍보부서 기획부서 추가(insert)
CREATE TABLE dept (#이 안에 생성할 column제목 column내용의 성격, ...나열
    id INT(10) UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY, #부서번호 
    ##primary key(a,b) 여러개 둘 때는 이렇게도 가능
    regDate DATETIME,
    `name` CHAR(100) NOT NULL    #부서명
);
DESC dept;

#alter table dept add column '홍보부서' text, '기획부서' text;

INSERT INTO dept SET regDate=NOW(), `name`='홍보';
INSERT INTO dept SET regDate=NOW(), `name`='기획';

DESC dept;
SELECT * FROM dept;
 
# 사원(emp) 테이블 생성 및 홍길동사원(홍보부서), 홍길순사원(홍보부서), 임꺽정사원(기획부서) 추가

CREATE TABLE emp (#이 안에 생성할 column제목 column내용의 성격, ...나열
    id INT(10) UNSIGNED NOT NULL AUTO_INCREMENT PRIMARY KEY, #부서번호 
    ##primary key(a,b) 여러개 둘 때는 이렇게도 가능
    regDate DATETIME NOT NULL,
    `name` CHAR(100) NOT NULL, #사원명  
    deptName CHAR(100) NOT NULL 
);
DESC dept;

DESC emp;
INSERT INTO emp SET regDate=NOW(),`name` = '홍길동' , deptName='홍보';
INSERT INTO emp SET regDate=NOW(),`name` = '홍길순' , deptName='홍보';
INSERT INTO emp SET regDate=NOW(),`name` = '임꺽정' , deptName='기획';


# 홍보를 마케팅으로 변경
#(두 테이블 다 바꾸기)
SELECT * FROM dept;
SELECT * FROM emp;

UPDATE dept SET `name`='마케팅' WHERE `name`='홍보';
UPDATE emp SET deptName='마케팅' WHERE deptName='홍보';
#UPDATE emp SET deptName='마케팅' WHERE `name='홍길%';

SELECT * FROM dept;
SELECT * FROM emp;

# 마케팅을 홍보로 변경
##그냥 동일하게
UPDATE dept SET `name`='홍보' WHERE `name`='마케팅';
UPDATE emp SET deptName='홍보' WHERE deptName='마케팅';

# 홍보를 마케팅으로 변경
# 구조를 변경하기로 결정(사원 테이블에서, 이제는 부서를 이름이 아닌 번호로 기억)
ALTER TABLE emp ADD COLUMN deptID INT(10) UNSIGNED NOT NULL; #부서번호 column생성
SELECT *FROM emp;

UPDATE emp SET deptId = 1 WHERE deptName = '홍보'; #홍보를 1로
UPDATE emp SET deptId = 2 WHERE deptName = '기획'; #기획을 2로
SELECT * FROM emp;

ALTER TABLE emp DROP COLUMN deptName; #부서이름 삭제

SELECT * FROM dept;
UPDATE dept SET `name` = '마케팅' WHERE `name` = '홍보';
SELECT * FROM dept;

# 사장님께 드릴 인명록을 생성
SELECT * FROM emp; #부서가 숫자로 나와있는 상태

SELECT 
emp.*, dept. `name` #emp 전체와 dept의 name을
FROM emp INNER JOIN dept #emp 안에 dept를
ON dept.id = emp.deptId;  #dept의 id가 emp의 deptid와 같을 때만

# 사장님께서 부서번호가 아니라 부서명을 알고 싶어하신다.
# 그래서 dept 테이블 조회법
SELECT * FROM dept WHERE id = 1;
#을 알려드리고 혼이 났다.

# 사장님께 드릴 인명록을 생성(v2, 부서명 포함, ON 없이)
SELECT emp.*, dept.name AS `부서명`
FROM emp INNER JOIN dept; #3*2 = 6
# 이상한 데이터가 생성되어서 혼남

# 사장님께 드릴 인명록을 생성(v3, 부서명 포함, 올바른 조인 룰(ON) 적용)
# 보고용으로 좀 더 편하게 보여지도록 고쳐야 한다고 지적받음
SELECT emp.*, dept.id, dept.name AS `부서명`
FROM emp INNER JOIN dept
ON emp.deptId = dept.id;

SELECT * FROM emp;

# 사장님께 드릴 인명록을 생성(v4, 사장님께서 보시기에 편한 칼럼명(AS))
SELECT 
emp.id AS `사원번호`,
emp.name AS `사원명`,
DATE(emp.regDate) AS `입사일`,
dept.name AS `부서명`
FROM emp INNER JOIN dept
ON emp.deptId = dept.id
ORDER BY `부서명`, `사원번호`;
