# 1. 손흥민(userName)의 주문 개수(COUNT)는? ???
SELECT * FROM t_user;
SELECT * FROM t_user WHERE userName='손흥민'; #e단서: t_user.userName='손흥민'/id=1
SELECT COUNT(*) FROM t_order WHERE userNo = 1; #t_user.id=t_order.userNo

SELECT t_order.*, t_user.* 
FROM t_order INNER JOIN t_user
ON t_order.userNo = t_user.id
WHERE t_user.userName ='손흥민'

SELECT COUNT(*)
FROM t_order INNER JOIN t_user
ON t_order.userNo = t_user.id
WHERE t_user.userName ='손흥민'

	SELECT t_user.userName, COUNT(t_order.id) AS '주문개수'   #t_order.id = 건수
	FROM t_user JOIN t_order ON t_user.id = t_order.userNo   #고객+주문, 고객의id=주문의 주문자
	WHERE t_user.userName = '손흥민' GROUP BY t_user.userName;#고객명 손홍민일때, 고객며을 묶어 

# 2. 손흥민이 산 상품은? ???
## 손흥민(고객)이 : t_user.userName='손흥민' -> t_user.id 확인 : 
## 산(t_order) 상품: t_order.productNo = t_product.id -> t_product.pname )

SELECT * FROM t_user;
SELECT * FROM t_user 
WHERE userName = '손흥민'; #단서: t_user.userName='손흥민' / id=1
SELECT * FROM t_order WHERE userNo = 1; # 단서: userNo =1=손흥민 productNo = 1, 5, 1
SELECT * FROM t_product WHERE id = 1 OR id = 5; # 동일 WHERE id in (1,5)
SELECT pname FROM t_product WHERE id = 1 OR id = 5;

#산 상품(t_product.pname)
SELECT t_product.pname #테이들 다 보고싶으면 *
FROM t_order INNER JOIN t_user
ON t_order.userNo = t_user.id

JOIN t_product
ON t_product.id = t_order.productNo

WHERE t_user.userName ='손흥민';


	SELECT t_user.userName, t_product.pname #고객.고객이름, 제품.제품명 을 골라 
	FROM t_user JOIN t_order                #고객.+order. (고객이 주문했는지)
	ON t_user.id = t_order.userNo           #고객.id = 주문.고객번호 일때

	JOIN t_product  			# +제품.
	ON t_order.productNo = t_product.id	#주문.제품번호 = 제품.id
	WHERE t_user.userName = '손흥민';	#누구? 사용자가 손홍민일때

