<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <title>구구단 문제</title>
</head>
<body>

<script>
    // 2~9단 중 하나 선택
    let dan = Math.floor(Math.random() * 8) + 2;

    // 1~9 중 하나 선택
    let su = Math.floor(Math.random() * 9) + 1;

    // 정답 계산
    let answer = dan * su;

    // 사용자에게 문제 제시
    let user = prompt(`${dan} × ${su} = ?`);

    // 문자열을 숫자로 변환
    user = Number(user);

    // 정답 확인
    if (user === answer) {
        alert("정답입니다!");
    } else {
        alert(`오답입니다. 정답은 ${answer}입니다.`);
    }
</script>

</body>
</html>
